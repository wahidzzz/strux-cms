/**
 * Unit tests for RBAC Engine
 * 
 * Tests:
 * - Loading RBAC configuration
 * - Permission evaluation for all roles
 * - Wildcard permissions (action: *, subject: all)
 * - Conditional permissions (e.g., createdBy: ${user.id})
 * - Field-level permissions
 * - Template variable resolution
 */

import { describe, it, expect, beforeEach, afterEach } from 'vitest'
import { RBACEngine } from './rbac-engine.js'
import { promises as fs } from 'fs'
import { join } from 'path'
import { tmpdir } from 'os'
import type { RequestContext, Resource } from '../types/index.js'

describe('RBACEngine', () => {
  let testDir: string
  let rbacEngine: RBACEngine

  beforeEach(async () => {
    // Create temporary test directory
    testDir = join(tmpdir(), `rbac-test-${Date.now()}-${Math.random().toString(36).slice(2)}`)
    await fs.mkdir(testDir, { recursive: true })
    await fs.mkdir(join(testDir, '.cms'), { recursive: true })

    // Create default RBAC config
    const defaultConfig = {
      roles: {
        admin: {
          id: 'admin',
          name: 'Administrator',
          description: 'Full access',
          type: 'admin' as const,
          permissions: [
            {
              action: '*' as const,
              subject: 'all',
            },
          ],
        },
        editor: {
          id: 'editor',
          name: 'Editor',
          description: 'Can manage content',
          type: 'editor' as const,
          permissions: [
            { action: 'create' as const, subject: 'all' },
            { action: 'read' as const, subject: 'all' },
            { action: 'update' as const, subject: 'all' },
            { action: 'publish' as const, subject: 'all' },
            { action: 'unpublish' as const, subject: 'all' },
          ],
        },
        authenticated: {
          id: 'authenticated',
          name: 'Authenticated',
          description: 'Default role for authenticated users',
          type: 'authenticated' as const,
          permissions: [
            { action: 'read' as const, subject: 'all' },
            { action: 'create' as const, subject: 'all' },
            {
              action: 'update' as const,
              subject: 'all',
              conditions: { createdBy: '${user.id}' },
            },
          ],
        },
        public: {
          id: 'public',
          name: 'Public',
          description: 'Default role for unauthenticated users',
          type: 'public' as const,
          permissions: [{ action: 'read' as const, subject: 'all' }],
        },
      },
      defaultRole: 'authenticated',
    }

    await fs.writeFile(
      join(testDir, '.cms', 'rbac.json'),
      JSON.stringify(defaultConfig, null, 2)
    )

    rbacEngine = new RBACEngine(testDir)
  })

  afterEach(async () => {
    // Clean up test directory
    await fs.rm(testDir, { recursive: true, force: true })
  })

  describe('loadRBACConfig', () => {
    it('should load RBAC configuration from file', async () => {
      await rbacEngine.loadRBACConfig()

      const adminRole = rbacEngine.getRole('admin')
      expect(adminRole).toBeDefined()
      expect(adminRole?.name).toBe('Administrator')
      expect(adminRole?.permissions).toHaveLength(1)
      expect(adminRole?.permissions[0].action).toBe('*')
    })

    it('should throw error if config file does not exist', async () => {
      // Remove config file
      await fs.unlink(join(testDir, '.cms', 'rbac.json'))

      await expect(rbacEngine.loadRBACConfig()).rejects.toThrow('RBAC config not found')
    })

    it('should throw error if config is invalid JSON', async () => {
      await fs.writeFile(join(testDir, '.cms', 'rbac.json'), 'invalid json')

      await expect(rbacEngine.loadRBACConfig()).rejects.toThrow()
    })

    it('should throw error if roles is missing', async () => {
      await fs.writeFile(
        join(testDir, '.cms', 'rbac.json'),
        JSON.stringify({ defaultRole: 'admin' })
      )

      await expect(rbacEngine.loadRBACConfig()).rejects.toThrow(
        'Invalid RBAC config: roles must be an object'
      )
    })

    it('should throw error if defaultRole is missing', async () => {
      await fs.writeFile(
        join(testDir, '.cms', 'rbac.json'),
        JSON.stringify({ roles: {} })
      )

      await expect(rbacEngine.loadRBACConfig()).rejects.toThrow(
        'Invalid RBAC config: defaultRole must be a string'
      )
    })

    it('should throw error if defaultRole does not exist in roles', async () => {
      await fs.writeFile(
        join(testDir, '.cms', 'rbac.json'),
        JSON.stringify({ roles: {}, defaultRole: 'nonexistent' })
      )

      await expect(rbacEngine.loadRBACConfig()).rejects.toThrow(
        'Default role "nonexistent" not found in roles'
      )
    })
  })

  describe('can - Admin role', () => {
    beforeEach(async () => {
      await rbacEngine.loadRBACConfig()
    })

    it('should grant admin all permissions with wildcard', async () => {
      const context: RequestContext = { role: 'admin' }
      const resource: Resource = { type: 'articles' }

      expect(await rbacEngine.can(context, 'create', resource)).toBe(true)
      expect(await rbacEngine.can(context, 'read', resource)).toBe(true)
      expect(await rbacEngine.can(context, 'update', resource)).toBe(true)
      expect(await rbacEngine.can(context, 'delete', resource)).toBe(true)
      expect(await rbacEngine.can(context, 'publish', resource)).toBe(true)
      expect(await rbacEngine.can(context, 'unpublish', resource)).toBe(true)
    })

    it('should grant admin access to any content type', async () => {
      const context: RequestContext = { role: 'admin' }

      expect(await rbacEngine.can(context, 'read', { type: 'articles' })).toBe(true)
      expect(await rbacEngine.can(context, 'read', { type: 'pages' })).toBe(true)
      expect(await rbacEngine.can(context, 'read', { type: 'products' })).toBe(true)
    })
  })

  describe('can - Editor role', () => {
    beforeEach(async () => {
      await rbacEngine.loadRBACConfig()
    })

    it('should grant editor create, read, update, publish, unpublish permissions', async () => {
      const context: RequestContext = { role: 'editor' }
      const resource: Resource = { type: 'articles' }

      expect(await rbacEngine.can(context, 'create', resource)).toBe(true)
      expect(await rbacEngine.can(context, 'read', resource)).toBe(true)
      expect(await rbacEngine.can(context, 'update', resource)).toBe(true)
      expect(await rbacEngine.can(context, 'publish', resource)).toBe(true)
      expect(await rbacEngine.can(context, 'unpublish', resource)).toBe(true)
    })

    it('should deny editor delete permission', async () => {
      const context: RequestContext = { role: 'editor' }
      const resource: Resource = { type: 'articles' }

      expect(await rbacEngine.can(context, 'delete', resource)).toBe(false)
    })
  })

  describe('can - Authenticated role', () => {
    beforeEach(async () => {
      await rbacEngine.loadRBACConfig()
    })

    it('should grant authenticated users read and create permissions', async () => {
      const context: RequestContext = {
        role: 'authenticated',
        user: { id: 'user-1', username: 'john', email: 'john@example.com', role: 'authenticated' },
      }
      const resource: Resource = { type: 'articles' }

      expect(await rbacEngine.can(context, 'read', resource)).toBe(true)
      expect(await rbacEngine.can(context, 'create', resource)).toBe(true)
    })

    it('should grant update permission only for own content', async () => {
      const context: RequestContext = {
        role: 'authenticated',
        user: { id: 'user-1', username: 'john', email: 'john@example.com', role: 'authenticated' },
      }

      // Own content
      const ownResource: Resource = {
        type: 'articles',
        id: 'article-1',
        data: { id: 'article-1', title: 'My Article', createdBy: 'user-1' },
      }

      expect(await rbacEngine.can(context, 'update', ownResource)).toBe(true)

      // Other user's content
      const otherResource: Resource = {
        type: 'articles',
        id: 'article-2',
        data: { id: 'article-2', title: 'Other Article', createdBy: 'user-2' },
      }

      expect(await rbacEngine.can(context, 'update', otherResource)).toBe(false)
    })

    it('should deny delete, publish, unpublish permissions', async () => {
      const context: RequestContext = {
        role: 'authenticated',
        user: { id: 'user-1', username: 'john', email: 'john@example.com', role: 'authenticated' },
      }
      const resource: Resource = {
        type: 'articles',
        data: { createdBy: 'user-1' },
      }

      expect(await rbacEngine.can(context, 'delete', resource)).toBe(false)
      expect(await rbacEngine.can(context, 'publish', resource)).toBe(false)
      expect(await rbacEngine.can(context, 'unpublish', resource)).toBe(false)
    })
  })

  describe('can - Public role', () => {
    beforeEach(async () => {
      await rbacEngine.loadRBACConfig()
    })

    it('should grant public users only read permission', async () => {
      const context: RequestContext = { role: 'public' }
      const resource: Resource = { type: 'articles' }

      expect(await rbacEngine.can(context, 'read', resource)).toBe(true)
    })

    it('should deny public users all write permissions', async () => {
      const context: RequestContext = { role: 'public' }
      const resource: Resource = { type: 'articles' }

      expect(await rbacEngine.can(context, 'create', resource)).toBe(false)
      expect(await rbacEngine.can(context, 'update', resource)).toBe(false)
      expect(await rbacEngine.can(context, 'delete', resource)).toBe(false)
      expect(await rbacEngine.can(context, 'publish', resource)).toBe(false)
      expect(await rbacEngine.can(context, 'unpublish', resource)).toBe(false)
    })
  })

  describe('can - Unknown role', () => {
    beforeEach(async () => {
      await rbacEngine.loadRBACConfig()
    })

    it('should deny all permissions for unknown role', async () => {
      const context: RequestContext = { role: 'unknown' }
      const resource: Resource = { type: 'articles' }

      expect(await rbacEngine.can(context, 'read', resource)).toBe(false)
      expect(await rbacEngine.can(context, 'create', resource)).toBe(false)
      expect(await rbacEngine.can(context, 'update', resource)).toBe(false)
      expect(await rbacEngine.can(context, 'delete', resource)).toBe(false)
    })
  })

  describe('evaluateConditions', () => {
    beforeEach(async () => {
      await rbacEngine.loadRBACConfig()
    })

    it('should evaluate simple equality conditions', () => {
      const context: RequestContext = {
        role: 'authenticated',
        user: { id: 'user-1', username: 'john', email: 'john@example.com', role: 'authenticated' },
      }
      const resource: Resource = {
        type: 'articles',
        data: { createdBy: 'user-1' },
      }

      const result = rbacEngine.evaluateConditions(
        { createdBy: 'user-1' },
        resource,
        context
      )

      expect(result).toBe(true)
    })

    it('should evaluate template variables', () => {
      const context: RequestContext = {
        role: 'authenticated',
        user: { id: 'user-1', username: 'john', email: 'john@example.com', role: 'authenticated' },
      }
      const resource: Resource = {
        type: 'articles',
        data: { createdBy: 'user-1' },
      }

      const result = rbacEngine.evaluateConditions(
        { createdBy: '${user.id}' },
        resource,
        context
      )

      expect(result).toBe(true)
    })

    it('should return false when condition does not match', () => {
      const context: RequestContext = {
        role: 'authenticated',
        user: { id: 'user-1', username: 'john', email: 'john@example.com', role: 'authenticated' },
      }
      const resource: Resource = {
        type: 'articles',
        data: { createdBy: 'user-2' },
      }

      const result = rbacEngine.evaluateConditions(
        { createdBy: '${user.id}' },
        resource,
        context
      )

      expect(result).toBe(false)
    })

    it('should return false when resource has no data', () => {
      const context: RequestContext = {
        role: 'authenticated',
        user: { id: 'user-1', username: 'john', email: 'john@example.com', role: 'authenticated' },
      }
      const resource: Resource = { type: 'articles' }

      const result = rbacEngine.evaluateConditions(
        { createdBy: '${user.id}' },
        resource,
        context
      )

      expect(result).toBe(false)
    })

    it('should handle multiple conditions (all must match)', () => {
      const context: RequestContext = {
        role: 'authenticated',
        user: { id: 'user-1', username: 'john', email: 'john@example.com', role: 'authenticated' },
      }
      const resource: Resource = {
        type: 'articles',
        data: { createdBy: 'user-1', status: 'draft' },
      }

      // All conditions match
      expect(
        rbacEngine.evaluateConditions(
          { createdBy: '${user.id}', status: 'draft' },
          resource,
          context
        )
      ).toBe(true)

      // One condition doesn't match
      expect(
        rbacEngine.evaluateConditions(
          { createdBy: '${user.id}', status: 'published' },
          resource,
          context
        )
      ).toBe(false)
    })
  })

  describe('canAccessField', () => {
    beforeEach(async () => {
      // Create config with field-level permissions
      const configWithFieldPerms = {
        roles: {
          admin: {
            id: 'admin',
            name: 'Administrator',
            description: 'Full access',
            type: 'admin' as const,
            permissions: [{ action: '*' as const, subject: 'all' }],
          },
          restricted: {
            id: 'restricted',
            name: 'Restricted',
            description: 'Limited field access',
            type: 'custom' as const,
            permissions: [
              {
                action: 'read' as const,
                subject: 'articles',
                fields: ['title', 'content'],
              },
            ],
          },
        },
        defaultRole: 'restricted',
      }

      await fs.writeFile(
        join(testDir, '.cms', 'rbac.json'),
        JSON.stringify(configWithFieldPerms, null, 2)
      )

      await rbacEngine.loadRBACConfig()
    })

    it('should allow access to all fields when no field restrictions', () => {
      const context: RequestContext = { role: 'admin' }

      expect(rbacEngine.canAccessField(context, 'articles', 'title')).toBe(true)
      expect(rbacEngine.canAccessField(context, 'articles', 'content')).toBe(true)
      expect(rbacEngine.canAccessField(context, 'articles', 'secret')).toBe(true)
    })

    it('should allow access only to specified fields', () => {
      const context: RequestContext = { role: 'restricted' }

      expect(rbacEngine.canAccessField(context, 'articles', 'title')).toBe(true)
      expect(rbacEngine.canAccessField(context, 'articles', 'content')).toBe(true)
      expect(rbacEngine.canAccessField(context, 'articles', 'secret')).toBe(false)
    })

    it('should deny access when no permissions for content type', () => {
      const context: RequestContext = { role: 'restricted' }

      expect(rbacEngine.canAccessField(context, 'pages', 'title')).toBe(false)
    })

    it('should deny access for unknown role', () => {
      const context: RequestContext = { role: 'unknown' }

      expect(rbacEngine.canAccessField(context, 'articles', 'title')).toBe(false)
    })
  })

  describe('getRole', () => {
    beforeEach(async () => {
      await rbacEngine.loadRBACConfig()
    })

    it('should return role by ID', () => {
      const role = rbacEngine.getRole('admin')

      expect(role).toBeDefined()
      expect(role?.id).toBe('admin')
      expect(role?.name).toBe('Administrator')
    })

    it('should return null for unknown role', () => {
      const role = rbacEngine.getRole('unknown')

      expect(role).toBeNull()
    })

    it('should throw error if config not loaded', () => {
      const engine = new RBACEngine(testDir)

      expect(() => engine.getRole('admin')).toThrow('RBAC config not loaded')
    })
  })

  describe('getAllRoles', () => {
    beforeEach(async () => {
      await rbacEngine.loadRBACConfig()
    })

    it('should return all roles', () => {
      const roles = rbacEngine.getAllRoles()

      expect(roles).toHaveLength(4)
      expect(roles.map((r) => r.id)).toContain('admin')
      expect(roles.map((r) => r.id)).toContain('editor')
      expect(roles.map((r) => r.id)).toContain('authenticated')
      expect(roles.map((r) => r.id)).toContain('public')
    })
  })

  describe('getDefaultRole', () => {
    beforeEach(async () => {
      await rbacEngine.loadRBACConfig()
    })

    it('should return default role', () => {
      const defaultRole = rbacEngine.getDefaultRole()

      expect(defaultRole).toBe('authenticated')
    })
  })

  describe('Specific content type permissions', () => {
    beforeEach(async () => {
      // Create config with specific content type permissions
      const configWithSpecificPerms = {
        roles: {
          articleEditor: {
            id: 'articleEditor',
            name: 'Article Editor',
            description: 'Can only edit articles',
            type: 'custom' as const,
            permissions: [
              { action: 'read' as const, subject: 'articles' },
              { action: 'update' as const, subject: 'articles' },
            ],
          },
        },
        defaultRole: 'articleEditor',
      }

      await fs.writeFile(
        join(testDir, '.cms', 'rbac.json'),
        JSON.stringify(configWithSpecificPerms, null, 2)
      )

      await rbacEngine.loadRBACConfig()
    })

    it('should grant permission for specific content type', async () => {
      const context: RequestContext = { role: 'articleEditor' }

      expect(await rbacEngine.can(context, 'read', { type: 'articles' })).toBe(true)
      expect(await rbacEngine.can(context, 'update', { type: 'articles' })).toBe(true)
    })

    it('should deny permission for other content types', async () => {
      const context: RequestContext = { role: 'articleEditor' }

      expect(await rbacEngine.can(context, 'read', { type: 'pages' })).toBe(false)
      expect(await rbacEngine.can(context, 'update', { type: 'pages' })).toBe(false)
    })
  })

  describe('createRole', () => {
    beforeEach(async () => {
      await rbacEngine.loadRBACConfig()
    })

    it('should create a new custom role', async () => {
    const newRole = await rbacEngine.createRole({
      name: 'Content Manager',
      description: 'Can manage all content',
      type: 'custom',
      permissions: [
        { action: 'create', subject: 'all' },
        { action: 'read', subject: 'all' },
        { action: 'update', subject: 'all' },
        { action: 'delete', subject: 'all' },
      ],
    })

    expect(newRole.id).toBe('content-manager')
    expect(newRole.name).toBe('Content Manager')
    expect(newRole.type).toBe('custom')
    expect(newRole.permissions).toHaveLength(4)

    // Verify role was persisted
    const role = rbacEngine.getRole('content-manager')
    expect(role).toBeDefined()
    expect(role?.name).toBe('Content Manager')
  })

  it('should throw error if role name is missing', async () => {
    await expect(
      rbacEngine.createRole({
        name: '',
        description: 'Test',
        type: 'custom',
        permissions: [],
      })
    ).rejects.toThrow('Role name is required')
  })

  it('should throw error if role description is missing', async () => {
    await expect(
      rbacEngine.createRole({
        name: 'Test Role',
        description: '',
        type: 'custom',
        permissions: [],
      })
    ).rejects.toThrow('Role description is required')
  })

  it('should throw error if role type is invalid', async () => {
    await expect(
      rbacEngine.createRole({
        name: 'Test Role',
        description: 'Test',
        type: 'invalid' as any,
        permissions: [],
      })
    ).rejects.toThrow('Role type must be one of')
  })

  it('should throw error if permissions is not an array', async () => {
    await expect(
      rbacEngine.createRole({
        name: 'Test Role',
        description: 'Test',
        type: 'custom',
        permissions: 'invalid' as any,
      })
    ).rejects.toThrow('Role permissions must be an array')
  })

  it('should throw error if permission action is invalid', async () => {
    await expect(
      rbacEngine.createRole({
        name: 'Test Role',
        description: 'Test',
        type: 'custom',
        permissions: [
          { action: 'invalid' as any, subject: 'all' },
        ],
      })
    ).rejects.toThrow('Invalid permission action')
  })

  it('should throw error if role already exists', async () => {
    await rbacEngine.createRole({
      name: 'Test Role',
      description: 'Test',
      type: 'custom',
      permissions: [],
    })

    await expect(
      rbacEngine.createRole({
        name: 'Test Role',
        description: 'Test',
        type: 'custom',
        permissions: [],
      })
    ).rejects.toThrow('Role with ID "test-role" already exists')
  })

  describe('updateRole', () => {
    beforeEach(async () => {
      await rbacEngine.loadRBACConfig()

      // Create a custom role to update
    await rbacEngine.createRole({
      name: 'Test Role',
      description: 'Original description',
      type: 'custom',
      permissions: [
        { action: 'read', subject: 'all' },
      ],
    })
  })

  it('should update role name', async () => {
    const updated = await rbacEngine.updateRole('test-role', {
      name: 'Updated Role',
    })

    expect(updated.name).toBe('Updated Role')
    expect(updated.description).toBe('Original description')

    // Verify persistence
    const role = rbacEngine.getRole('test-role')
    expect(role?.name).toBe('Updated Role')
  })

  it('should update role description', async () => {
    const updated = await rbacEngine.updateRole('test-role', {
      description: 'Updated description',
    })

    expect(updated.description).toBe('Updated description')
  })

  it('should update role permissions', async () => {
    const updated = await rbacEngine.updateRole('test-role', {
      permissions: [
        { action: 'create', subject: 'all' },
        { action: 'read', subject: 'all' },
        { action: 'update', subject: 'all' },
      ],
    })

    expect(updated.permissions).toHaveLength(3)
  })

  it('should update multiple fields at once', async () => {
    const updated = await rbacEngine.updateRole('test-role', {
      name: 'New Name',
      description: 'New description',
      permissions: [
        { action: 'create', subject: 'articles' },
      ],
    })

    expect(updated.name).toBe('New Name')
    expect(updated.description).toBe('New description')
    expect(updated.permissions).toHaveLength(1)
  })

  it('should throw error if role not found', async () => {
    await expect(
      rbacEngine.updateRole('nonexistent', { name: 'Test' })
    ).rejects.toThrow('Role with ID "nonexistent" not found')
  })

  it('should throw error if name is invalid', async () => {
    await expect(
      rbacEngine.updateRole('test-role', { name: '' })
    ).rejects.toThrow('Role name must be a non-empty string')
  })

  it('should throw error if description is invalid', async () => {
    await expect(
      rbacEngine.updateRole('test-role', { description: '' })
    ).rejects.toThrow('Role description must be a non-empty string')
  })

  it('should throw error if type is invalid', async () => {
    await expect(
      rbacEngine.updateRole('test-role', { type: 'invalid' as any })
    ).rejects.toThrow('Role type must be one of')
  })

  it('should throw error if permissions is not an array', async () => {
    await expect(
      rbacEngine.updateRole('test-role', { permissions: 'invalid' as any })
    ).rejects.toThrow('Role permissions must be an array')
  })

  it('should throw error if permission action is invalid', async () => {
    await expect(
      rbacEngine.updateRole('test-role', {
        permissions: [{ action: 'invalid' as any, subject: 'all' }],
      })
    ).rejects.toThrow('Invalid permission action')
  })

  it('should not change role ID', async () => {
    const updated = await rbacEngine.updateRole('test-role', {
      name: 'New Name',
    })

    expect(updated.id).toBe('test-role')
  })

  describe('deleteRole', () => {
    beforeEach(async () => {
      await rbacEngine.loadRBACConfig()

      // Create a custom role to delete
    await rbacEngine.createRole({
      name: 'Deletable Role',
      description: 'Can be deleted',
      type: 'custom',
      permissions: [],
    })
  })

  it('should delete a custom role', async () => {
    await rbacEngine.deleteRole('deletable-role')

    const role = rbacEngine.getRole('deletable-role')
    expect(role).toBeNull()
  })

  it('should throw error if role not found', async () => {
    await expect(
      rbacEngine.deleteRole('nonexistent')
    ).rejects.toThrow('Role with ID "nonexistent" not found')
  })

  it('should throw error when deleting admin role', async () => {
    await expect(
      rbacEngine.deleteRole('admin')
    ).rejects.toThrow('Cannot delete default role "admin"')
  })

  it('should throw error when deleting editor role', async () => {
    await expect(
      rbacEngine.deleteRole('editor')
    ).rejects.toThrow('Cannot delete default role "editor"')
  })

  it('should throw error when deleting authenticated role', async () => {
    await expect(
      rbacEngine.deleteRole('authenticated')
    ).rejects.toThrow('Cannot delete default role "authenticated"')
  })

  it('should throw error when deleting public role', async () => {
    await expect(
      rbacEngine.deleteRole('public')
    ).rejects.toThrow('Cannot delete default role "public"')
  })

  it('should throw error when deleting the default role', async () => {
    // Create a custom role and set it as default
    await rbacEngine.createRole({
      name: 'Custom Default',
      description: 'Custom default role',
      type: 'custom',
      permissions: [],
    })

    // Manually update config to set custom role as default
    const configPath = join(testDir, '.cms', 'rbac.json')
    const config = JSON.parse(await fs.readFile(configPath, 'utf-8'))
    config.defaultRole = 'custom-default'
    await fs.writeFile(configPath, JSON.stringify(config, null, 2))
    await rbacEngine.loadRBACConfig()

    await expect(
      rbacEngine.deleteRole('custom-default')
    ).rejects.toThrow('Cannot delete the default role "custom-default"')
  })

  it('should persist deletion to disk', async () => {
    await rbacEngine.deleteRole('deletable-role')

    // Create new engine instance and load config
    const newEngine = new RBACEngine(testDir)
    await newEngine.loadRBACConfig()

    const role = newEngine.getRole('deletable-role')
    expect(role).toBeNull()
  })
})

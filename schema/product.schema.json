{
  "displayName": "Product",
  "kind": "collectionType",
  "singularName": "product",
  "pluralName": "products",
  "description": "Product listings for the e-commerce demo.",
  "apiId": "product",
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "price": {
      "type": "number",
      "required": true
    },
    "sku": {
      "type": "string",
      "required": true
    },
    "stock": {
      "type": "number",
      "required": true
    },
    "on_sale": {
      "type": "boolean",
      "required": false
    },
    "sale_price": {
      "type": "number",
      "required": false
    },
    "images": {
      "type": "media",
      "required": false
    },
    "product_category": {
      "type": "relation",
      "relation": {
        "target": "product-category",
        "relation": "manyToOne"
      }
    },
    "specs": {
      "type": "json",
      "required": false
    }
  }
}

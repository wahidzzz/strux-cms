{
  "displayName": "Article",
  "kind": "collectionType",
  "singularName": "article",
  "pluralName": "articles",
  "description": "Educational blog posts and news articles.",
  "apiId": "article",
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text",
      "required": false
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "publish_date": {
      "type": "date",
      "required": false
    },
    "reading_time": {
      "type": "number",
      "required": false
    },
    "is_featured": {
      "type": "boolean",
      "required": false
    },
    "tags": {
      "type": "json",
      "required": false
    },
    "author": {
      "type": "relation",
      "relation": {
        "target": "profile",
        "relation": "manyToOne"
      }
    },
    "category": {
      "type": "relation",
      "relation": {
        "target": "category",
        "relation": "manyToOne"
      }
    },
    "featured_image": {
      "type": "media",
      "required": false
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "seo"
    }
  }
}
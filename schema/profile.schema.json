{
  "displayName": "Profile",
  "kind": "collectionType",
  "singularName": "profile",
  "pluralName": "profiles",
  "description": "User profiles for authors and team members.",
  "apiId": "profile",
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "string",
      "required": false
    },
    "twitter_handle": {
      "type": "string",
      "required": false
    },
    "bio": {
      "type": "text",
      "required": false
    },
    "role": {
      "type": "string",
      "required": false
    },
    "joined_at": {
      "type": "date",
      "required": false
    },
    "image": {
      "type": "media",
      "required": false
    },
    "articles": {
      "type": "relation",
      "relation": {
        "target": "article",
        "relation": "oneToMany"
      }
    }
  }
}